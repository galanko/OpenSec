# OpenSec Docker environment
# Copy to .env and fill in your values:  cp .env.example .env

# AI provider keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Credential vault key (base64-encoded 32-byte key)
# Generate with:  python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
OPENSEC_CREDENTIAL_KEY=

# App port (default 8000)
# OPENSEC_APP_PORT=8000
